{
  "name": "uc-smile-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:setup": "tsx src/scripts/setup-db.ts",
    "db:push": "tsx src/scripts/setup-db.ts && drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/setup-db.ts && drizzle-kit migrate"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.7.0",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
