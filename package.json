{
  "name": "uc-smile-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:setup": "npm run migration:run",
    "db:migrate": "npm run migration:run",
    "typeorm": "typeorm",
    "migration:create": "typeorm migration:create src/lib/db/migrations/Migration",
    "migration:generate": "npm run build && typeorm migration:generate src/lib/db/migrations/GeneratedMigration -d dist/lib/db/data-source.js",
    "migration:run": "npm run build && node dist/scripts/run-migration.js run",
    "migration:revert": "npm run build && node dist/scripts/run-migration.js revert",
    "migration:show": "tsx src/scripts/show-migration-status.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.30"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
